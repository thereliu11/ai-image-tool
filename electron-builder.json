{
    "appId": "com.ai-teaching.tool",
    "productName": "智绘AI",
    "asar": true,
    "electronVersion": "31.7.7",
    "electronDist": "node_modules/electron/dist",
    "publish": [
        {
            "provider": "github",
            "owner": "thereliu11",
            "repo": "ai-image-tool",
            "releaseType": "release"
        }
    ],
    "directories": {
        "output": "release"
    },
    "files": [
        "src/main/**/*",
        "src/preload/**/*",
        "src/shared/**/*",
        "dist/renderer/**/*",
        "assets/**/*",
        "package.json"
    ],
    "win": {
        "target": [
            "nsis",
            "portable"
        ],
        "icon": "assets/icon.png"
    },
    "nsis": {
        "oneClick": false,
        "allowToChangeInstallationDirectory": true,
        "createDesktopShortcut": true,
        "createStartMenuShortcut": true,
        "shortcutName": "智绘AI"
    },
    "portable": {
        "artifactName": "${productName}-${version}-portable.exe"
    }
}
